{
  "name": "@livelayer/sdk",
  "version": "0.7.6",
  "description": "LiveLayer Agent Widget — drop-in web component for embedding LiveLayer agents",
  "keywords": [
    "livelayer",
    "ai-agent",
    "voice-agent",
    "avatar",
    "livekit",
    "web-component",
    "widget"
  ],
  "homepage": "https://livelayer.studio",
  "main": "dist/widget.js",
  "module": "dist/widget.mjs",
  "types": "dist/widget.d.ts",
  "exports": {
    ".": {
      "types": "./dist/widget.d.ts",
      "import": "./dist/widget.mjs",
      "require": "./dist/widget.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.bridge.config.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "livekit-client": "^2.17.3"
  },
  "devDependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.0.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fusion-Studios-Code/live-layer-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Fusion-Studios-Code/live-layer-sdk/issues"
  }
}
